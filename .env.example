# =========================
# App / Runtime
# =========================
NODE_ENV=development
PORT=5000
APP_NAME=Fitout Manager
APP_URL=http://localhost:3000

# =========================
# Database
# =========================
MONGODB_URI=mongodb://localhost:27017/fitout-manager
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=2

# =========================
# Frontend / CORS
# =========================
FRONTEND_URL=http://localhost:3000
PROD_FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGIN=

# =========================
# JWT / Session / Cookies
# =========================
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
ACCESS_TOKEN_EXPIRY=30m
REFRESH_TOKEN_EXPIRY=30d
SESSION_COOKIE_NAME=fitout_session
REFRESH_COOKIE_NAME=fitout_refresh
SESSION_MAX_AGE=1800000
SESSION_REFRESH_THRESHOLD=300000
SESSION_ABSOLUTE_TIMEOUT=86400000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# =========================
# Security
# =========================
CSRF_ENABLED=false
CSRF_SECRET=replace-with-strong-secret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=20
SKIP_RATE_LIMIT=false

# =========================
# Redis (Optional)
# =========================
REDIS_URL=
REDIS_PASSWORD=

# =========================
# Storage (Cloudflare R2)
# =========================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fitoutmanager
R2_PUBLIC_URL=

# =========================
# Email (SMTP)
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=
EMAIL_FROM=

# =========================
# Email (AWS SES)
# =========================
AWS_SES_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=

# =========================
# Background maintenance
# =========================
CLEANUP_API_KEY=

# =========================
# Stripe Subscription Billing
# =========================
# Secret API key from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=

# Webhook signing secret from Stripe Dashboard > Developers > Webhooks
# Endpoint should be: https://your-api-domain.com/api/payments/webhook
STRIPE_WEBHOOK_SECRET=

# Recurring monthly price IDs from Stripe Products
# Starter 29 USD/month
STRIPE_PRICE_STARTER=
# Team 99 USD/month
STRIPE_PRICE_TEAM=
# Enterprise 120 USD/month
STRIPE_PRICE_ENTERPRISE=
