# ============================================
# LOCAL DEVELOPMENT ENVIRONMENT - BACKEND
# ============================================
# Use this for local development only
# Save as: backend/.env
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# ============================================
# JWT SECRETS - DEVELOPMENT ONLY
# ============================================
# These are for development only - NEVER use in production
JWT_ACCESS_SECRET=dev-fitout-manager-access-secret-2024-minimum-32-chars-long
JWT_REFRESH_SECRET=dev-fitout-manager-refresh-secret-2024-minimum-32-chars-long
CSRF_SECRET=dev-fitout-manager-csrf-secret-2024-minimum-32-chars-long

# ============================================
# TOKEN EXPIRY - LONGER FOR DEVELOPMENT
# ============================================
ACCESS_TOKEN_EXPIRY=30m
REFRESH_TOKEN_EXPIRY=7d

# ============================================
# COOKIE CONFIGURATION - LOCAL SETTINGS
# ============================================
SESSION_COOKIE_NAME=fitout_session
REFRESH_COOKIE_NAME=fitout_refresh

# Local development: secure=false, sameSite=lax
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=localhost

# ============================================
# SECURITY SETTINGS - RELAXED FOR DEVELOPMENT
# ============================================
CSRF_ENABLED=false

# ============================================
# FRONTEND URLS - LOCAL DEVELOPMENT
# ============================================
FRONTEND_URL=http://localhost:3000
PROD_FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ============================================
# DATABASE - MONGODB
# ============================================
# Using your MongoDB Atlas connection
MONGODB_URI=MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ============================================
# CLOUDINARY CONFIGURATION
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# REDIS (OPTIONAL - Uncomment if using Redis locally)
# ============================================
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_TTL=3600

# ============================================
# SESSION MANAGEMENT
# ============================================
SESSION_MAX_AGE=1800000
SESSION_REFRESH_THRESHOLD=300000
SESSION_ABSOLUTE_TIMEOUT=86400000

RATE_LIMIT_AUTH_MAX=50
SKIP_RATE_LIMIT=false

AWS_ACCESS_KEY_ID=AKIATT5UGVFY5RHXVUHX
AWS_SECRET_ACCESS_KEY=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
AWS_SES_REGION=ap-southeast-2
SES_FROM_EMAIL=fitoutmanagerofficial@gmail.com
APP_NAME=Fitout Manager AU
APP_URL=http://localhost:3000                                         
